# ytb2bili runtime config example
# Copy to config.toml and edit only the fields you actually need.

listen = ":8096"
environment = "development"
debug = false
fileUpDir = "./data"
data_path = "./data"
yt_dlp_path = ""
auto_upload = false
primary_ai_service = ""

[database]
type = "sqlite"
database = "data/ytb2bili.db"
timezone = "Asia/Shanghai"

[auth]
jwt_secret = ""
jwt_expiration = 24
session_secret = "change-this-session-secret"

[api_auth]
app_id = ""
app_secret = ""
cookies_decrypt_key = ""

[ProxyConfig]
use_proxy = false
proxy_host = "http://127.0.0.1:10809"

[WhisperConfig]
enabled = true
language = "en"
model_path = ""
threads = 0

[DeepLXConfig]
enabled = false
endpoint = ""
source_lang = "EN"
target_lang = "ZH"
timeout = 30

[OpenAICompatibleConfig]
enabled = false
provider = "local"
api_key = ""
base_url = "http://127.0.0.1:11434/v1"
model = "qwen2.5:7b"
timeout = 60
max_tokens = 4000
temperature = 0.7

[DeepSeekTransConfig]
enabled = false
api_key = ""
models = "deepseek-chat"
endpoint = "https://api.deepseek.com"
timeout = 60
max_tokens = 4000

[GeminiConfig]
enabled = false
api_key = ""
model = "gemini-2.5-flash"
timeout = 120
max_tokens = 8000
use_for_metadata = false
analyze_video = true
video_sample_frames = 0

[BilibiliConfig]
copyright = 1
source = ""
no_reprint = 1
use_original_title = false
use_original_desc = false
custom_title_template = ""
custom_desc_template = ""
tid = 122
dynamic = "发布了新视频！"
open_elec = 0
selection_reserve = 0
up_selection_reply = 0
up_close_reply = 0
up_close_reward = 1

[TenCosConfig]
enabled = false
cos_bucket_url = ""
cos_secret_id = ""
cos_secret_key = ""
cos_region = ""
cos_bucket = ""
sub_app_id = ""

[AnalyticsConfig]
enabled = false
server_url = "http://localhost:8080"
api_key = ""
product_id = "bili-up-api"
debug = false
