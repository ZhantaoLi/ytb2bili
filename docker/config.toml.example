# ytb2bili 配置文件示例（TOML格式）
# 复制此文件为 config.toml 并根据实际情况修改
# 注意：环境变量会覆盖此文件中的配置

# ============================================================================
# 应用基础配置
# ============================================================================

[server]
host = "0.0.0.0"           # 服务监听地址，0.0.0.0 表示监听所有网卡
port = 8096                # 服务端口
static_dir = "./downloads" # 静态文件目录（视频、字幕等）
static_path = "/static"    # 静态文件访问路径前缀


# ============================================================================
# 数据库配置
# ============================================================================
[database]
type = "mysql"
host = "mysql"                 # Docker Compose 服务名
port = 3306
user = "ytb2bili"              # 与 docker-compose.yml 一致
password = "ytb2bili@123"
dbname = "bili_up"             # 数据库名（注意是 dbname 不是 database）
sslmode = ""                   # MySQL 不使用（仅 PostgreSQL 需要）
timezone = "Asia/Shanghai"     # 时区配置
auto_migrate = true
table_prefix = ""



# ============================================================================
# 视频处理工作流配置
# ============================================================================
[workflow]
download_dir = "./downloads"  # 视频下载目录（必需，应与 server.static_dir 保持一致）

# yt-dlp 可执行文件路径（可选，默认从 PATH 查找）
ytdlp_path = "/usr/local/bin/yt-dlp"

# ffmpeg 可执行文件路径（可选，默认从 PATH 查找）
ffmpeg_path = "/usr/bin/ffmpeg"
# Cookies 文件路径（可选，用于下载受限视频）
# cookies_file = "/path/to/cookies.txt"

# 微软语音服务配置（可选，用于旧版翻译功能）
# speech_key = "your_azure_speech_key"
# speech_region = "eastasia"

# LLM 翻译配置（默认关闭，免费流程直接保留原始字幕）
llm_translation_enabled = false     # 是否启用本地 LLM 批量翻译
llm_translation_batch_size = 25      # 批量翻译每批句子数
llm_translation_max_workers = 3      # 并发工作者数量
llm_translation_context_size = 2     # 上下文窗口大小
llm_translation_source_lang = "en"   # 源语言代码
llm_translation_target_lang = "zh-Hans"  # 目标语言代码

# TTS 字幕音频合成配置（默认关闭，免费流程不依赖外部语音服务）
tts_enabled = false  # 是否启用字幕音频合成

# ============================================================================
# Agent & LLM 配置（可选，仅用于自行配置的 API 或本地兼容接口）
# 默认免费流程不需要 API；如需启用，请自行配置 base_url、model、api_key。
# ============================================================================
[agent]
name = "agent"  # Agent 名称

# 字幕翻译 API（可选，默认关闭）
# DeepLX 适合直接翻译字幕句子；endpoint 必须由使用者自行填写完整 /translate 地址。
[DeepLXConfig]
enabled = false
endpoint = ""
source_lang = "EN"
target_lang = "ZH"
timeout = 30

# OpenAI 兼容翻译接口（可选，默认关闭）
# 可配置本地 Ollama/new-api/one-api 或其他兼容 /v1/chat/completions 的服务。
[OpenAICompatibleConfig]
enabled = false
provider = "local"
api_key = ""
base_url = "http://127.0.0.1:11434/v1"
model = "qwen2.5:7b"
timeout = 60
max_tokens = 4000
temperature = 0.7

# 代理配置（可选，用于 yt-dlp 下载、字幕获取等网络请求）
# Docker 容器访问宿主机代理时通常使用 host.docker.internal。
[ProxyConfig]
use_proxy = false
proxy_host = "http://host.docker.internal:10809"

# ============================================================================
# 自动更新配置
# ============================================================================
[updater]
enabled = true         # 是否启用更新检查
auto_update = false    # 是否自动更新（建议设为 false，手动更新更安全）
check_interval = 24    # 检查更新间隔（小时），0 表示禁用
# update_url = "https://api.github.com/repos/zolagz/ytb2bili/releases/latest"
# current_version = "0.0.1"



# ============================================================================
# 腾讯云 COS 存储配置（可选，用于云端存储）
# ============================================================================
[tencos]
enabled = false  # 是否启用腾讯云 COS 存储
# cos_bucket_url = "https://your-bucket.cos.ap-guangzhou.myqcloud.com"
# cos_secret_id = "your_secret_id"
# cos_secret_key = "your_secret_key"
# cos_region = "ap-guangzhou"
# cos_bucket = "your-bucket-name"
# sub_app_id = "your_app_id"

